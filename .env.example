# rebind — example configuration
#
# All variables are optional; the defaults shown match the built-in defaults.
# Copy this file to .env and edit it — the binary loads .env automatically on
# startup. Real environment variables take precedence over values in .env, e.g.:
#
#   cp .env.example .env
#   ./target/release/rebind
#   REBIND_HOSTNAME=other.test ./target/release/rebind   # overrides .env

# ---------------------------------------------------------------- DNS server
# UDP+TCP bind address for the nameserver. Port 53 needs root; use a high port
# (e.g. 0.0.0.0:5353) for unprivileged local testing.
REBIND_DNS_BIND=0.0.0.0:53

# TTL (seconds) placed on every answer. 0 disables client-side caching, which
# is what rebinding wants so the victim re-resolves quickly.
REBIND_DNS_TTL=0

# Seeds a project's DNS padding count. The rebind name carries only the target
# IP; this server injects its own IP (REBIND_SERVER_IP) into the answer — always
# once (the anchor the browser lands on first), plus this many EXTRA copies
# (e.g. 3 -> the answer holds the target plus 4 server-IP records, shuffled;
# 0 -> just the target plus one server IP). Some browsers favor the first
# reachable record and only fail over once it stops responding, so the extra
# copies bias them onto our server first, then `/stop` pushes them to the
# target. Max 16. Editable per-project under the dashboard's Advanced settings.
REBIND_DNS_PAD=0

# --------------------------------------------------------------- web servers
# The master and standard servers bind independently, so each can be pinned to
# its own private IP.

# Master / orchestrator server (operator dashboard + runner). Binds exactly as
# configured — IPv4 only by default; it does NOT bind IPv6. Typically pinned to
# a private management IP.
REBIND_CONTENT_BIND=0.0.0.0:3000

# Standard-port server (serves the JS payload / rebind frame + GET /stop). Port
# 80 needs root; the iframe URL port and the /stop port come from the FIRST bind
# entry. A wildcard bind (0.0.0.0:p or [::]:p) listens on BOTH IPv4 and IPv6 on
# the same port (a dual-stack [::]:p socket), so a victim that resolves the
# rebind name over AAAA (REBIND_SERVER_IP6) still reaches it over IPv6.
#
# This may be a COMMA-SEPARATED LIST of addresses to bind several at once — e.g.
# a private IPv4 plus a specific IPv6 (all entries should share the same port):
#   REBIND_STANDARD_BIND=10.0.2.210:80,[fd00::210]:80
REBIND_STANDARD_BIND=0.0.0.0:80

# SQLite database backing HTTP Basic auth on the master server. On first run it
# is created and an `admin` user is seeded with a random password printed once
# to the log — record it then. The standard-port server is NOT authenticated.
REBIND_AUTH_DB=rebind-auth.db

# ----------------------------------------------- deployment (.env only)
# These identify where/how this server runs and are NOT editable from the
# master web UI. The dashboard shows them read-only.

# Base domain for the rebind workers, delegated to this DNS server. Iframe hosts
# are built as <target_ip>.<random>.<REBIND_HOSTNAME> — only the target is
# encoded; this server's IP is injected into the answer from REBIND_SERVER_IP
# below.
REBIND_HOSTNAME=rebind.example.com

# Optional public base URL for the master/runner when it is hosted separately
# from the rebind workers (its own domain, possibly behind a TLS reverse proxy).
# Used as-is to build the runner link handed to a target, so include the scheme
# and any non-default port; a bare host with no scheme defaults to https. Leave
# unset to build runner links from whatever origin the operator opens the
# dashboard on.
# REBIND_MASTER_URL=https://master.example.com

# Public IPv4 of THIS server's standard-port web server. Browsers connect here
# first; the master also calls /stop on this IP. It is injected into every A
# answer (the anchor) alongside the decoded target.
REBIND_SERVER_IP=127.0.0.1

# Optional public IPv6 of THIS server. AAAA queries are answered with ONLY this
# single address — the target is never exposed over IPv6, keeping the rebind on
# the v4 path we control. Leave unset to return NODATA (empty) for AAAA.
# REBIND_SERVER_IP6=2001:db8::1

# ------------------------------------------ project defaults (web-editable)
# These seed the "default" project on startup; create/edit/save projects from
# the dashboard. (Saved projects live under REBIND_PROJECTS_DIR.)

# Comma-separated list of target IPs to rebind to — one iframe is created per
# target. e.g. REBIND_TARGETS=192.168.0.1,10.0.0.1,127.0.0.1
REBIND_TARGETS=127.0.0.1

# How many seconds the master asks /stop to keep the standard server offline,
# giving the browser time to fail over to the target IP. Capped at 20s.
REBIND_STOP_SECONDS=5

# Path to the JS payload run inside each iframe after rebinding. The file must
# define `async function runPayload(rebind)` (see payload.js). If unset or
# unreadable, a built-in default payload is used.
REBIND_PAYLOAD_FILE=payload.js

# Directory where saved projects (targets + stop + payload) are stored.
REBIND_PROJECTS_DIR=projects

# -------------------------------------------------------------------- logging
# tracing-subscriber EnvFilter. Examples: info | rebind=debug | warn
RUST_LOG=rebind=info,info

# ----------------------------------------------------------------------------
# Unprivileged local-testing overrides (uncomment to run without root):
# REBIND_DNS_BIND=0.0.0.0:5353
# REBIND_STANDARD_BIND=0.0.0.0:8080
